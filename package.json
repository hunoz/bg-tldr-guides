{
    "private": true,
    "packageManager": "pnpm@8.15.1",
    "scripts": {
        "app:start": "pnpm --filter @rulesnap/app web",
        "app:format": "pnpm --filter @rulesnap/app format",
        "app:lint:fix": "pnpm --filter @rulesnap/app lint:fix",
        "app:lint:check": "pnpm --filter @rulesnap/app lint:check",
        "app:build": "pnpm --filter @rulesnap/app build",
        "app:ios": "pnpm --filter @rulesnap/app ios",
        "app:android": "pnpm --filter @rulesnap/app android",
        "infra:synth": "pnpm --filter @rulesnap/infra synth",
        "infra:bootstrap": "pnpm app:build && pnpm --filter @rulesnap/infra bootstrap",
        "infra:deploy": "pnpm app:build && pnpm --filter @rulesnap/infra run deploy",
        "infra:diff": "pnpm --filter @rulesnap/infra diff"
    }
}
