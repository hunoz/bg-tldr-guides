{
    "name": "@rulesnap/app",
    "version": "1.0.0",
    "private": true,
    "main": "expo-router/entry",
    "scripts": {
        "generate": "node scripts/generate-all.js",
        "expo": "expo",
        "start": "npm run generate && expo start",
        "build": "npm run generate && expo export --platform web",
        "format": "prettier --write .",
        "lint:check": "eslint . --ext .ts,.tsx",
        "lint:fix": "eslint . --ext .ts,.tsx --fix",
        "android": "npm run generate && expo run:android",
        "ios": "npm run generate && expo run:ios",
        "web": "npm run generate && expo start --web",
        "test": "npm run generate && jest"
    },
    "dependencies": {
        "@babel/runtime": "^7.26.0",
        "@expo-google-fonts/cinzel": "^0.2.0",
        "@expo-google-fonts/crimson-text": "^0.2.0",
        "@react-native-async-storage/async-storage": "1.23.1",
        "expo": "~52.0.0",
        "expo-font": "~13.0.0",
        "expo-linking": "~7.0.0",
        "expo-localization": "~16.0.0",
        "expo-router": "~4.0.0",
        "i18next": "^24.0.0",
        "react": "^18.3.0",
        "react-dom": "^18.3.0",
        "react-i18next": "^15.0.0",
        "react-native": "^0.76.9",
        "react-native-safe-area-context": "^4.12.0",
        "react-native-screens": "^4.4.0",
        "react-native-svg": "15.8.0",
        "react-native-web": "^0.19.13",
        "zustand": "^5.0.0"
    },
    "devDependencies": {
        "@expo/metro-runtime": "~4.0.0",
        "@types/jest": "^29.5.0",
        "@types/react": "^18.3.0",
        "chokidar": "^5.0.0",
        "eslint": "^9.39.4",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "fast-check": "^3.22.0",
        "globals": "^17.4.0",
        "jest": "^29.7.0",
        "prettier": "^3.8.1",
        "react-native-svg-transformer": "^1.5.3",
        "ts-jest": "^29.2.0",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.57.0"
    }
}
