{
    "compilerOptions": {
        "target": "ES2023",
        "module": "commonjs",
        "lib": ["ES2023"],
        "declaration": true,
        "strict": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "noImplicitThis": true,
        "alwaysStrict": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "outDir": "./cdk.out/ts",
        "rootDir": ".",
        "skipLibCheck": true
    },
    "include": ["bin/**/*.ts", "lib/**/*.ts"]
}
